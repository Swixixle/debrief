  "scripts": {
    "dev": "NODE_ENV=development node --env-file=.env --import tsx server/index.ts",
    "build": "tsx scripts/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc || echo '\n⚠️  Type errors exist. This is a known issue tracked in docs/internal/TYPECHECK_TODO.md\n   We do not fail CI on type errors currently to avoid blocking development.\n   Please avoid introducing new type errors in your changes.\n'",
    "check:security": "tsx scripts/check_spawn_security.ts",
    "test": "npm run test:unit",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "smoke": "bash scripts/smoke_debrief.sh",
    "debrief": "node -r ts-node/register/transpile-only server/cli.ts",
    "reporecon": "node -r ts-node/register/transpile-only server/cli.ts",
    "test:unit": "vitest run",
    "desktop:dev": "cd client && npx tauri dev",
    "desktop:build": "cd client && npx tauri build"
  },
