{
  "name": "debrief",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Read any codebase. Get a verified plain-language brief.",
  "homepage": "https://github.com/Swixixle/debrief#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Swixixle/debrief.git"
  },
  "bugs": {
    "url": "https://github.com/Swixixle/debrief/issues"
