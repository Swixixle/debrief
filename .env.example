# --- OpenAI (Python analyzer LLM + optional Whisper) ---
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# Legacy aliases also read by tooling:
OPENAI_API_KEY=
DEBRIEF_OPENAI_API_KEY=
DEBRIEF_ANALYZER_MODEL=gpt-4.1

# --- HTTP server ---
PORT=5000
NODE_ENV=development
HOST=0.0.0.0

# --- Python ---
PYTHON_EXEC_PATH=python3
ANALYZER_TIMEOUT_MS=600000

# --- Database ---
DATABASE_URL=postgresql://debrief:debrief@localhost:5432/debrief

# --- Redis (BullMQ + run cache) ---
REDIS_URL=redis://localhost:6379
DEBRIEF_USE_BULLMQ=0

# --- API guard (optional in dev) ---
API_KEY=
ADMIN_KEY=

# --- Clerk (auth, optional in dev) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- Stripe (billing, optional) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUILDER=price_...
STRIPE_PRICE_STUDIO=price_...
STRIPE_PRICE_UNLIMITED=price_...

# Billing enforcement (off until you are ready)
DEBRIEF_BILLING_ACTIVE=0
APP_URL=http://localhost:5000

# --- Desktop / local path ingest ---
DEBRIEF_ALLOW_LOCAL_PATHS=0

# --- CORS (production) ---
ALLOWED_ORIGINS=
