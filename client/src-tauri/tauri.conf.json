{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Debrief",
  "version": "0.1.0",
  "identifier": "com.debrief.app",
  "build": {
    "frontendDist": "../../dist/public",
    "devUrl": "http://localhost:5000",
    "beforeBuildCommand": "cd ../.. && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Debrief",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
